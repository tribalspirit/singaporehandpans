# Environment Variables Template - Copy to .env and fill in your values

# Storyblok CMS
STORYBLOK_TOKEN=your_storyblok_preview_token_here
STORYBLOK_SPACE_ID=your_space_id_here
STORYBLOK_MANAGEMENT_TOKEN=your_management_token_here

# Development
NODE_ENV=development
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_SITE_NAME="Singapore Handpan Studio"

# Optional - Analytics
PUBLIC_GA4_ID=your_ga4_id_here
PUBLIC_GTM_ID=your_gtm_id_here

# Optional - Social Media
PUBLIC_FACEBOOK_HANDLE=singaporehandpan
PUBLIC_INSTAGRAM_HANDLE=singaporehandpan

# Acuity Scheduling - Booking Integration
PUBLIC_ACUITY_OWNER_ID=your_acuity_owner_id
PUBLIC_ACUITY_CALENDAR_ID=your_acuity_calendar_id
PUBLIC_ACUITY_WORKSHOP_URL=https://app.acuityscheduling.com/schedule.php?owner=YOUR_ID&calendarID=YOUR_CALENDAR_ID
PUBLIC_ACUITY_PRIVATE_URL=https://app.acuityscheduling.com/schedule.php?owner=YOUR_ID&appointmentType=YOUR_TYPE_ID
ACUITY_USER_ID=your_acuity_user_id
ACUITY_API_KEY=your_acuity_api_key
ACUITY_WEBHOOK_SECRET=your_webhook_secret

# Optional - Contact Info
PUBLIC_CONTACT_EMAIL=singaporehandpanstudio@gmail.com
PUBLIC_STUDIO_ADDRESS="123 Music Street, Level 2, Singapore 123456"

# Shop - Shopify Integration (disabled by default)
PUBLIC_ENABLE_SHOP=false
PUBLIC_SHOPIFY_STORE_DOMAIN=your-store-name.myshopify.com
PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token_here
