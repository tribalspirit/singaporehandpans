---
import { fetchAllCollections, isShopEnabled } from '../../lib/shopifyClient';
import type { ShopCollection } from '../../lib/shopifyClient';

function getShortDescription(description: string): string {
  if (!description) return '';
  const firstSentence = description.match(/^[^.]+\./)?.[0] ?? description;
  if (firstSentence.length > 120) {
    return firstSentence.slice(0, 117).replace(/\s+$/, '') + '...';
  }
  return firstSentence;
}

const shopEnabled = isShopEnabled();
let partners: ShopCollection[] = [];

if (shopEnabled) {
  try {
    const { collections } = await fetchAllCollections();
    partners = collections.filter((c) => c.image && c.productCount > 0);
  } catch {
    // Fail silently — section will be hidden
  }
}

const shouldRender = shopEnabled && partners.length > 0;
---

{
  shouldRender && (
    <section class="partners" aria-labelledby="partners-heading">
      <div class="container">
        <div class="partners__header">
          <span class="partners__eyebrow" aria-hidden="true">
            Partners
          </span>
          <h2 id="partners-heading" class="partners__title">
            Our Partners
          </h2>
          <p class="partners__subtitle">
            We work with leading handpan makers and accessory brands from around
            the world.
          </p>
        </div>

        <ul class="partners__grid" aria-label="Our partner brands">
          {partners.map((partner) => (
            <li>
              <a
                href={`/shop/${partner.handle}/`}
                class="partner-card"
                aria-label={`${partner.title} — view collection`}
              >
                <div class="partner-card__logo-wrapper">
                  <img
                    src={partner.image!.url}
                    alt={partner.image!.altText || `${partner.title} logo`}
                    class="partner-card__logo"
                    loading="lazy"
                    width="260"
                    height="260"
                  />
                </div>
                <div class="partner-card__content">
                  <h3 class="partner-card__name">{partner.title}</h3>
                  {getShortDescription(partner.description) && (
                    <p class="partner-card__description">
                      {getShortDescription(partner.description)}
                    </p>
                  )}
                  <span class="partner-card__count">
                    {partner.productCount}{' '}
                    {partner.productCount === 1 ? 'product' : 'products'}
                  </span>
                </div>
              </a>
            </li>
          ))}
        </ul>

        <div class="partners__cta">
          <a href="/shop/" class="partners__cta-link">
            Browse all brands
            <svg
              class="partners__cta-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="m9 18 6-6-6-6" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )
}

<style lang="scss">
  .partners {
    padding: var(--space-16) 0;
    background-color: var(--color-white);

    @media (min-width: 768px) {
      padding: var(--space-24) 0;
    }
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-6);

    @media (max-width: 768px) {
      padding: 0 var(--space-4);
    }
  }

  .partners__header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .partners__eyebrow {
    display: block;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .partners__title {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-900);
    margin-bottom: var(--space-4);
    line-height: var(--line-height-tight);
  }

  .partners__subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-gray-600);
    max-width: 600px;
    margin: 0 auto;
    line-height: var(--line-height-relaxed);
  }

  .partners__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);

    @media (min-width: 768px) {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
    }

    @media (min-width: 1024px) {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .partner-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      transform var(--transition-fast),
      box-shadow var(--transition-fast);
    height: 100%;

    &:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-md);
    }

    &:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: 2px;
    }

    @media (prefers-reduced-motion: reduce) {
      transition: none;
    }
  }

  .partner-card__logo-wrapper {
    aspect-ratio: 1;
    background: var(--color-gray-100);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    overflow: hidden;
  }

  .partner-card__logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .partner-card__content {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    flex: 1;

    @media (min-width: 768px) {
      padding: var(--space-4) var(--space-5);
    }
  }

  .partner-card__name {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-gray-900);
    margin-bottom: var(--space-2);
    line-height: var(--line-height-tight);

    @media (min-width: 768px) {
      font-size: var(--font-size-lg);
    }
  }

  .partner-card__description {
    font-size: var(--font-size-xs);
    color: var(--color-gray-600);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-2);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;

    @media (min-width: 768px) {
      font-size: var(--font-size-sm);
      -webkit-line-clamp: 3;
    }
  }

  .partner-card__count {
    font-size: var(--font-size-xs);
    color: var(--color-gray-500);
  }

  .partners__cta {
    text-align: center;
    margin-top: var(--space-10);
  }

  .partners__cta-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-primary);
    font-weight: var(--font-weight-medium);
    font-size: var(--font-size-base);
    text-decoration: none;
    min-height: 44px;

    &:hover {
      color: var(--color-primary-dark);
      text-decoration: underline;
    }

    &:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: 2px;
      border-radius: var(--radius-sm);
    }
  }

  .partners__cta-icon {
    width: 16px;
    height: 16px;
  }
</style>
