---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShopProductList from '../../components/ShopProductList';
import { fetchAllCollections, isShopEnabled } from '../../lib/shopifyClient';
import { setEdgeCache } from '../../lib/edgeCache';
import type { ShopProduct, ShopCollection } from '../../lib/shopifyClient';

export const prerender = false;
setEdgeCache(Astro.response, 'medium');

if (!isShopEnabled()) {
  return Astro.redirect('/404');
}

let collections: ShopCollection[] = [];
let products: ShopProduct[] = [];
let collectionProductMap: Record<string, string[]> = {};
let error: Error | null = null;

try {
  const result = await fetchAllCollections();
  collections = result.collections;
  products = result.allProducts;
  collectionProductMap = result.collectionProductMap;
} catch (err) {
  console.error('Failed to fetch shop data:', err);
  error = err instanceof Error ? err : new Error('Unknown error');
}

const pageTitle = 'Handpan Shop Singapore';
const pageDescription =
  'Buy handcrafted handpans and accessories in Singapore. Browse premium hand pan drums from MAG, Battiloro, Sirvan & SEW — ember steel, stainless steel, cases, stands & more.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={`${Astro.site}shop/`}
>
  <main class="shop-page">
    <section class="hero-section">
      <div class="container">
        <h1 class="page-title">Handpan Shop</h1>
        <p class="page-subtitle">
          Buy handpans, hand pan drums, cases, stands and accessories from
          trusted makers. Browse by brand or explore our full collection.
        </p>
      </div>
    </section>

    {
      error ? (
        <section class="shop-section">
          <div class="container">
            <div class="error-state">
              <p>Shop is temporarily unavailable. Please try again later.</p>
            </div>
          </div>
        </section>
      ) : (
        <>
          {collections.length > 0 && (
            <section class="collections-section">
              <div class="container">
                <h2 class="section-title">Browse by Brand</h2>
                <div class="collections-grid">
                  {collections.map((col) => (
                    <a href={`/shop/${col.handle}/`} class="collection-card">
                      <div class="collection-image-wrapper">
                        {col.image ? (
                          <img
                            src={col.image.url}
                            alt={col.image.altText || col.title}
                            loading="lazy"
                            width="400"
                            height="225"
                          />
                        ) : (
                          <div class="collection-placeholder">
                            <svg
                              width="48"
                              height="48"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.5"
                            >
                              <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                            </svg>
                          </div>
                        )}
                      </div>
                      <div class="collection-info">
                        <h3 class="collection-name">{col.title}</h3>
                        <span class="collection-count">
                          {col.productCount}{' '}
                          {col.productCount === 1 ? 'product' : 'products'}
                        </span>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            </section>
          )}

          <section class="shop-section">
            <div class="container">
              <h2 class="section-title">All Products</h2>
              {products.length === 0 ? (
                <div class="empty-state">
                  <p>No products available yet. Check back soon!</p>
                </div>
              ) : (
                <ShopProductList
                  products={products}
                  collections={collections}
                  collectionProductMap={collectionProductMap}
                  client:load
                />
              )}
            </div>
          </section>
        </>
      )
    }
  </main>
</BaseLayout>

<style lang="scss">
  .shop-page {
    min-height: 100vh;
  }

  .hero-section {
    background: linear-gradient(
      135deg,
      var(--color-primary-light) 0%,
      var(--color-accent-light) 100%
    );
    padding: var(--space-16) 0 var(--space-12);
    text-align: center;

    @media (max-width: 768px) {
      padding: var(--space-12) 0 var(--space-8);
    }
  }

  .page-title {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-900);
    margin-bottom: var(--space-4);
    line-height: var(--line-height-tight);

    @media (min-width: 768px) {
      font-size: var(--font-size-5xl);
    }
  }

  .page-subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-gray-700);
    max-width: 600px;
    margin: 0 auto;
    line-height: var(--line-height-relaxed);

    @media (min-width: 768px) {
      font-size: var(--font-size-xl);
    }
  }

  .collections-section {
    padding: var(--space-12) 0 var(--space-8);
    background: var(--color-white);

    @media (max-width: 768px) {
      padding: var(--space-8) 0 var(--space-6);
    }
  }

  .section-title {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-900);
    margin-bottom: var(--space-8);

    @media (min-width: 768px) {
      font-size: var(--font-size-3xl);
    }
  }

  .collections-grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  }

  .collection-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      transform var(--transition-fast),
      box-shadow var(--transition-fast);

    &:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    &:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: 2px;
    }
  }

  .collection-image-wrapper {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-gray-100);
    padding: var(--space-4);

    img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      transition: transform var(--transition-normal);
    }

    .collection-card:hover & img {
      transform: scale(1.05);
    }
  }

  .collection-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: var(--color-gray-400);
  }

  .collection-info {
    padding: var(--space-4) var(--space-5);
  }

  .collection-name {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-gray-900);
    margin-bottom: var(--space-1);
    line-height: var(--line-height-tight);
  }

  .collection-count {
    font-size: var(--font-size-sm);
    color: var(--color-gray-500);
  }

  .shop-section {
    padding: var(--space-12) 0 var(--space-16);
    background: var(--color-gray-50);

    @media (max-width: 768px) {
      padding: var(--space-8) 0 var(--space-12);
    }
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--space-6);

    @media (max-width: 768px) {
      padding: 0 var(--space-4);
    }
  }

  .empty-state,
  .error-state {
    text-align: center;
    padding: var(--space-16);
    color: var(--color-gray-600);
    font-size: var(--font-size-lg);
  }

  .error-state {
    color: var(--color-error, var(--color-gray-600));
  }
</style>
